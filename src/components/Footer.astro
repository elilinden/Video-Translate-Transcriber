---
import { site, withBase } from '../data/site';
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <a class="brand footer-brand" href={withBase('/')} aria-label={`${site.name} home`}>
        <span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span>
        <span>{site.shortName}</span>
      </a>
      <p>Clear words, ready for wherever your video goes.</p>
    </div>
    <div class="footer-links">
      <div>
        <span class="footer-label">Explore</span>
        <a href={withBase('/how-it-works')}>How it works</a>
        <a href={withBase('/features')}>Features</a>
        <a href={withBase('/pricing')}>Pricing</a>
      </div>
      <div>
        <span class="footer-label">Help</span>
        <a href={withBase('/support')}>Support</a>
        <a href={withBase('/privacy')}>Privacy</a>
        <a href={withBase('/terms')}>Terms</a>
      </div>
    </div>
  </div>
  <div class="shell footer-bottom">
    <span>© 2026 {site.name}</span>
    <span>Designed for video with something to say.</span>
  </div>
</footer>
