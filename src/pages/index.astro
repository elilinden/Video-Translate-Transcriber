---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneMockup from '../components/PhoneMockup.astro';
import { featureCards, site, withBase } from '../data/site';
---

<BaseLayout page="home">
  <section class="hero section-pad">
    <div class="hero-halo" aria-hidden="true"></div>
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow hero-eyebrow"><span class="pulse-dot"></span>{site.announcement}</p>
        <h1>Make every word <em>land.</em></h1>
        <p class="hero-lede">Transcribe and translate spoken video, fine-tune the subtitles, and make a version your audience can actually follow.</p>
        <div class="button-row">
          <a class="button" href={withBase(site.appPath)}>Open the app <span aria-hidden="true">↗</span></a>
          <a class="text-link" href={withBase('/how-it-works')}>See how it works <span aria-hidden="true">↓</span></a>
        </div>
        <p class="micro-copy">Choose from 20 supported languages. Keep the edit simple.</p>
      </div>
      <div class="hero-art" aria-label="Video Translate Transcriber app preview">
        <span class="hero-sticker sticker-one">SPEAK<br />FREELY</span>
        <span class="hero-sticker sticker-two">20<br />LANGUAGES</span>
        <PhoneMockup variant="transcript" />
        <span class="hero-orbit orbit-one" aria-hidden="true"></span>
        <span class="hero-orbit orbit-two" aria-hidden="true"></span>
      </div>
    </div>
  </section>

  <section class="language-strip" aria-label="Supported languages">
    <div class="shell language-strip-inner">
      <p>From the first word to the final frame</p>
      <div class="language-list">
        {site.languages.slice(0, 8).map((language) => <span>{language}</span>)}
        <span class="language-plus">+ more</span>
      </div>
    </div>
  </section>

  <section class="section-pad process-section">
    <div class="shell">
      <div class="split-heading">
        <p class="eyebrow">ONE CLEAR FLOW</p>
        <h2>Get from spoken video to subtitles that feel considered.</h2>
        <a class="text-link" href={withBase('/how-it-works')}>The full process <span aria-hidden="true">↗</span></a>
      </div>
      <div class="feature-grid">
        {featureCards.map((feature, index) => (
          <article class:list={["feature-card", { offset: index === 1 }]}>
            <span class="feature-number">{feature.number}</span>
            <p class="eyebrow">{feature.eyebrow}</p>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad spotlight-section">
    <div class="shell spotlight-grid">
      <div class="spotlight-copy">
        <p class="eyebrow">BUILT FOR THE EDIT</p>
        <h2>Less fiddling. More finishing.</h2>
        <p>Review the transcript, change the language, then shape subtitles that stay readable without taking over the frame.</p>
        <a class="button button-dark" href={withBase('/features')}>Explore features <span aria-hidden="true">→</span></a>
      </div>
      <div class="spotlight-art"><PhoneMockup variant="style" /></div>
    </div>
  </section>

  <section class="closing-cta section-pad">
    <div class="shell closing-card">
      <p class="eyebrow">READY WHEN YOU ARE</p>
      <h2>Give your video a language everyone can follow.</h2>
      <a class="button" href={withBase(site.appPath)}>Open Video Translate Transcriber <span aria-hidden="true">↗</span></a>
    </div>
  </section>
</BaseLayout>
